DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nse_academy_api

JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d

PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

CMS_URL=http://localhost:1337
CMS_API_TOKEN=your-strapi-api-token

# Google Gemini AI Config
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash-latest

# RapidAPI Key for NSE Market Data
RAPID_API_KEY=a34e74be1bmsh6cc628ccac17f8fp11f24cjsnf0910247b8ab

# Admin API key — used to authenticate requests from the CMS user-manager plugin
ADMIN_API_KEY=your_secret_admin_key

PORT=3011
GA_PROPERTY_ID=your-property-id
GA_CLIENT_EMAIL=your-client-email
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Dexter file delivery API (ebook downloads)
DEXTER_API_KEY=dex_S0Zg8Rju8TMB78XdhoNann6jHiHj_8V8jFNfRVX1gfE

# Brevo (transactional email + contact sync for lead magnets / marketing).
# When BREVO_API_KEY is empty the BrevoService logs a warning and no-ops, so
# local dev works without one. Get the key + list id from app.brevo.com.
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=no-reply@nseacademy.vitaldigitalmedia.net
BREVO_SENDER_NAME=NSE Academy
# Optional — Brevo template id used for the lead-magnet welcome email. When
# unset, a built-in HTML email is sent so the flow works out of the box.
BREVO_LEAD_MAGNET_TEMPLATE_ID=

# Public site URL used in lead-magnet email links. Defaults to the prod URL.
SITE_URL=https://nseacademy.vitaldigitalmedia.net
